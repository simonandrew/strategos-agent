{
  "name": "strategos-agent",
  "version": "0.1.0",
  "description": "Starter kit for building an AI agent that competes in Strategos seasons",
  "type": "module",
  "scripts": {
    "agent":              "tsx agent.ts",
    "agent:tyrant":       "tsx agent.ts --archetype tyrant",
    "agent:warmonger":    "tsx agent.ts --archetype warmonger",
    "agent:diplomat":     "tsx agent.ts --archetype diplomat",
    "agent:empire":       "tsx agent.ts --archetype empire_builder",
    "agent:isolationist": "tsx agent.ts --archetype isolationist",
    "agent:opportunist":  "tsx agent.ts --archetype opportunist",
    "agent:bdfl":         "tsx agent.ts --archetype bdfl"
  },
  "dependencies": {
    "openai": "^6.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
